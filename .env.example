# Site
NEXT_PUBLIC_SITE_URL=https://canlitvrehber.com

# Ads (optional)
NEXT_PUBLIC_ADSENSE_CLIENT=
NEXT_PUBLIC_AD_SLOT_HOME_LEADERBOARD=
NEXT_PUBLIC_AD_SLOT_HOME_INFEED=
NEXT_PUBLIC_AD_SLOT_HOME_SIDEBAR_TOP=
NEXT_PUBLIC_AD_SLOT_HOME_SIDEBAR_BOTTOM=
NEXT_PUBLIC_AD_SLOT_WATCH_SIDEBAR_TOP=
NEXT_PUBLIC_AD_SLOT_WATCH_SIDEBAR_BOTTOM=
NEXT_PUBLIC_AD_SLOT_FAVORITES_LEADERBOARD=

# Hukuki Guvenli Mod
# true: guvenli filtre aktif (onerilen)
# false: tum dahili streamler acik (riskli)
NEXT_PUBLIC_SAFE_MODE=true

# Mod:
# strict    -> sadece izinli kanal/host (en guvenli)
# reference -> canlitv referansi aciksa oynat + izinli liste
NEXT_PUBLIC_SAFE_MODE_LEVEL=reference

# Direkt izlemeye izinli kanal ID listesi (virgulle)
# Bos birakirsan varsayilan dengeli liste kullanilir:
# trthaber,trtspor,trtbelgesel,trtcocuk
# Ornek ozel liste: trt1,trthaber,ntv
NEXT_PUBLIC_SAFE_DIRECT_CHANNEL_IDS=trthaber,trtspor,trtbelgesel,trtcocuk

# Direkt izlemeye izinli kaynak host listesi (virgulle)
# Ornek: tv-trt1.medya.trt.com.tr,tv-trthaber.medya.trt.com.tr
NEXT_PUBLIC_SAFE_DIRECT_HOSTS=tv-trt1.medya.trt.com.tr,trt1,tv-trthaber.medya.trt.com.tr,tv-trtspor.medya.trt.com.tr,tv-trtbelgesel.medya.trt.com.tr,tv-trtcocuk.medya.trt.com.tr

# Zorunlu dis baglanti (dahili playeri her zaman kapat)
# Ornek: tv8,nowtv
# canlitv.diy (2026-03-15) telif_redirect listesi ile senkron
NEXT_PUBLIC_SAFE_FORCE_EXTERNAL_CHANNEL_IDS=tv8,nowtv,spacetoonkidstv,cbcsport,agrotv
